{
  "name": "video-site",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:worker": "turbo -F worker dev",
    "db:push": "turbo -F @video-site/db db:push",
    "db:studio": "turbo -F @video-site/db db:studio",
    "db:generate": "turbo -F @video-site/db db:generate",
    "db:migrate": "turbo -F @video-site/db db:migrate",
    "db:reset": "turbo -F @video-site/db db:reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@video-site/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@video-site/config": "workspace:*",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
